{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "true",
    "ANTHROPIC_MODEL": "anthropic.claude-sonnet-4-6"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "ras-dev-toolkit@ras-marketplace": true,
    "cli-anything@cli-anything": true
  },
  "extraKnownMarketplaces": {
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skills": {
    "enabled": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/dlopez/.claude/statusline-command.sh"
  },
  "allowedCommands": [
    "go",
    "make",
    "git status",
    "git log",
    "git diff",
    "git branch",
    "git checkout",
    "git add",
    "git commit",
    "git pull",
    "npm test",
    "npm run",
    "npm install",
    "go test",
    "go build",
    "go mod tidy",
    "cargo build",
    "cargo test",
    "make",
    "pip install",
    "python",
    "node",
    "ls",
    "pwd",
    "cd",
    "cat",
    "head",
    "tail",
    "echo",
    "printf",
    "find",
    "grep",
    "rg",
    "stow"
  ],
  "model": "us.anthropic.claude-sonnet-4-6[1m]"
}
