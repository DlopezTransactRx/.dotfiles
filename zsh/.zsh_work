#******************************************************************************
# Work-related functions
# Note: This file depends on environment variables from .zsh_hidden
#******************************************************************************

function jwtToken(){
	# Notify User
	figlet "Fetching JWT Token"

	# Echo Source
	echo "JWT HOST = $DEV_JWT_HOST" | lolcat
	echo "CLIENT = $DEV_JWT_CLIENT" | lolcat
	echo "SECRET = $DEV_JWT_SECRET" | lolcat

	# Request Token
	jwtJson=$(curl -sS -X POST "$DEV_JWT_HOST" \
	  -H "Content-Type: application/x-www-form-urlencoded" \
	  -u "$DEV_JWT_CLIENT:$DEV_JWT_SECRET" \
	  -d "grant_type=client_credentials")

	#Echo Response Json
	echo "$jwtJson" | jq

	# Copy Token to Clipboard
	echo "$jwtJson" | jq -r '"Bearer " + .access_token' | pbcopy

	# Notify User
	cowsay 'JWT Token has been copied to the clipboard' | lolcat
}


#******************************************************************************
# Nats-Discover
#******************************************************************************
function ndd(){
	{
		figlet "[NATS Discover (Development)]"
		nats-discover -context Development "$@" 2>&1
	} | gum style --border-foreground 39 --foreground 39
}
function ndp(){
	{
		figlet "[NATS Discover (Production)]"
		nats-discover -context Production "$@" 2>&1
	} | gum style --border-foreground 196 --foreground 196
}

#******************************************************************************
# Network Connectivity Test
# Tests specific host:port combinations using netcat
# Targets are defined in .zsh_hidden (NETWORK_TEST_TARGETS array)
#******************************************************************************
function nt(){
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[1;34m'
    PURPLE='\033[38;5;129m'
    PINK='\033[38;5;213m'
    NC='\033[0m' # No Color

    # Check if array exists
    if [[ ${#NETWORK_TEST_TARGETS[@]} -eq 0 ]]; then
        echo -e "${RED}Error: NETWORK_TEST_TARGETS array not found${NC}"
        echo "Please ensure .zsh_hidden is sourced with NETWORK_TEST_TARGETS defined."
        return 1
    fi

    echo "=============================="
    echo "Starting connectivity tests..."
    echo "=============================="

    # Loop through each target
    for target in "${NETWORK_TEST_TARGETS[@]}"; do
	# Split host, port, and label
	label="${target%%|*}"     # Get everything before first "|"
	temp="${target#*|}"       # Remove label and first "|"
	host="${temp%%:*}"        # Get everything before last ":"
	port="${temp##*:}"        # Get everything after last ":"

	printf "${PINK}$label${NC} ${BLUE}$host${NC}:${YELLOW}$port${NC} ... "

	# Perform netcat test with timeout of 3 seconds
	if nc -zv -w3 "$host" "$port" 2>/dev/null; then
	    echo -e "${GREEN}OPEN${NC}"
	else
	    echo -e "${RED}CLOSED/FILTERED${NC}"
	fi
    done

    echo -e "\n${NC}Connectivity tests completed.${NC}"
}

