# Write Aws Environment .env file
function ak() {
  local envfile="${AWS_KEYS_FILE:-$HOME/.aws/.keys}"

  pbpaste | tr -d '\r' > "$envfile"
  echo "" >> "$envfile"
  echo "export AWS_REGION=us-east-1" >> "$envfile"
  chmod 600 "$envfile"

  gum style --foreground 226 "✓ AWS keys file updated from clipboard into $envfile"

}


# Load AWS Envionrment .Env File Into Shell
function al(){
  local envfile="${AWS_KEYS_FILE:-$HOME/.aws/.keys}"

  set -a
  source "$envfile"
  set +a
}

# Interactively select and export an AWS profile for the session
function awsp() {
  local profile
  profile=$(aws configure list-profiles | gum choose) || return
  [[ -n "$profile" ]] || return
  export AWS_PROFILE="$profile"
  aws sts get-caller-identity
}
