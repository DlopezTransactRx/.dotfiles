# Write Aws Environment .env file
function ak() {
  local envfile="${AWS_KEYS_FILE:-$HOME/.aws/.keys}"

  pbpaste | tr -d '\r' > "$envfile"
  echo "" >> "$envfile"
  echo "export AWS_REGION=us-east-1" >> "$envfile"
  chmod 600 "$envfile"

  gum style --foreground 226 "✓ AWS keys file updated from clipboard into $envfile"

}


# Load AWS Envionrment .Env File Into Shell
function al(){
  local envfile="${AWS_KEYS_FILE:-$HOME/.aws/.keys}"

  set -a
  source "$envfile"
  set +a
}

# alias aws="al && aws"
# alias awslogs="al && awslogs"
